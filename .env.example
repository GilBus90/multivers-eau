# Copie ce fichier en .env (en local) et renseigne les valeurs
# trouvées dans Firebase Console > Paramètres du projet > Général > Tes applications.
# Sur Vercel, ajoute les mêmes clés dans Project Settings > Environment Variables.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
